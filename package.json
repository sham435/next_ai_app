{
  "name": "scrape-platform",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "build:shared": "cd packages/shared-types && npm run build",
    "lint": "turbo run lint",
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && npm run start:dev",
    "dev:worker": "cd apps/worker && npm run dev",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.0",
  "overrides": {
    "ioredis": "5.3.2"
  }
}
