# ============================================
# Scrape Platform — Environment Variables
# ============================================
# Copy this file to .env and fill in values.

# ============================================
# Application
# ============================================
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PORT=4000

# ============================================
# Redis (BullMQ Queue)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# Railway Redis Reference (production)
# REDIS_HOST=${{Redis.REDIS_HOST}}
# REDIS_PASSWORD=${{Redis.REDIS_PASSWORD}}

# ============================================
# API (NestJS)
# ============================================
FRONTEND_URL=http://localhost:3000
DOWNLOAD_DIR=./download
REQUEST_TIMEOUT=10000
BULL_BOARD_PASSWORD=changeme

# ============================================
# Worker
# ============================================
WORKER_CONCURRENCY=5
RATE_LIMIT_MAX=50
RATE_LIMIT_DURATION=60000

# ============================================
# Frontend (Next.js)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:4000

# ============================================
# OpenTelemetry (Optional)
# ============================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ============================================
# Storage (S3 Compatible - MinIO for local)
# ============================================
STORAGE_BASE_URL=http://localhost:9000
STORAGE_S3_ACCESS_KEY_ID=minioadmin
STORAGE_S3_SECRET_ACCESS_KEY=minioadmin
STORAGE_S3_BUCKET=myagent
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ENDPOINT=http://localhost:9000

# ============================================
# Billing Provider (stripe or polar)
# ============================================
NEXT_PUBLIC_BILLING_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
POLAR_ACCESS_TOKEN=

# ============================================
# API Keys for LLM Providers
# ============================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENAI_API_KEY=

# ============================================
# Auth (OAuth - Optional)
# ============================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# Railway Database Reference (production)
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# ============================================
# Railway Deployment
# ============================================
# FRONTEND_URL=https://your-frontend.up.railway.app
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
# REDIS_HOST=${{Redis.REDIS_HOST}}
# REDIS_PASSWORD=${{Redis.REDIS_PASSWORD}}
