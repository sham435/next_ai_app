{
  "dashboard": {
    "id": null,
    "uid": "scrape-platform",
    "title": "Scrape Platform Dashboard",
    "tags": ["scrape", "production"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "API Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job=\"scrape-api\"}[5m])) by (status)",
            "legendFormat": "{{status}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "API Latency (P95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"scrape-api\"}[5m])) by (le))",
            "legendFormat": "P95"
          }
        ]
      },
      {
        "id": 3,
        "title": "Scrape Jobs Total",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum(scrape_jobs_total)",
            "legendFormat": "Total Jobs"
          }
        ]
      },
      {
        "id": 4,
        "title": "Queue Depth",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
        "targets": [
          {
            "expr": "scrape_queue_waiting",
            "legendFormat": "Waiting"
          }
        ]
      },
      {
        "id": 5,
        "title": "Job Success Rate",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "1 - (sum(rate(scrape_jobs_failed_total[5m])) / sum(rate(scrape_jobs_total[5m])))",
            "legendFormat": "Success Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.9 },
                { "color": "green", "value": 0.95 }
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Worker Count",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
        "targets": [
          {
            "expr": "count(kube_pod_info{namespace=\"scrape-system\",pod=~\"scrape-worker.*\"})",
            "legendFormat": "Workers"
          }
        ]
      },
      {
        "id": 7,
        "title": "Redis Memory Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "redis_memory_used_bytes",
            "legendFormat": "Used"
          },
          {
            "expr": "redis_memory_max_bytes",
            "legendFormat": "Max"
          }
        ]
      },
      {
        "id": 8,
        "title": "Pod CPU Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"scrape-system\"}[5m])) by (pod)",
            "legendFormat": "{{pod}}"
          }
        ]
      }
    ]
  }
}
